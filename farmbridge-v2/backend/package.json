{
  "name": "farmbridge-backend",
  "version": "2.0.0",
  "description": "FarmBridge API — Nigerian Multilingual Marketplace",
  "main": "server.js",
  "scripts": {
    "dev":         "nodemon server.js",
    "start":       "node server.js",
    "db:generate": "prisma generate",
    "db:migrate":  "prisma migrate dev",
    "db:push":     "prisma db push",
    "db:studio":   "prisma studio",
    "db:seed":     "node scripts/seed.js",
    "db:reset":    "prisma migrate reset --force && node scripts/seed.js",
    "test:api":    "node scripts/test-api.js"
  },
  "dependencies": {
    "@prisma/client":          "^5.10.0",
    "cloudinary":              "^2.0.0",
    "cors":                    "^2.8.5",
    "dotenv":                  "^16.4.1",
    "express":                 "^4.18.2",
    "express-validator":       "^7.0.1",
    "multer":                  "^1.4.5-lts.1",
    "multer-storage-cloudinary":"^4.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "prisma":  "^5.10.0"
  }
}
